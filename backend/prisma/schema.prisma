datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String
  name            String
  role            String         @default("USER") // USER, ADMIN
  points          Int            @default(0)
  level           String         @default("Beginner")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?      // Soft delete support

  calculations    Calculation[]
  habits          DailyHabit[]
  challenges      UserChallenge[]
  receipts        ReceiptScan[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
}

model Calculation {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Inputs
  transportMode   String   
  travelDistance  Float    
  electricity     Float    
  acUsage         Float    
  diet            String   
  shoppingOnline  Int      
  shoppingFashion Int      
  recyclingHabit  String   
  plasticUsage    String   
  
  // Outputs
  transportCO2    Float
  energyCO2       Float
  foodCO2         Float
  shoppingCO2     Float
  wasteCO2        Float
  totalCO2        Float
  carbonScore     Int      
  rating          String   
  
  createdAt       DateTime  @default(now())
  deletedAt       DateTime? // Soft delete support

  @@index([userId])
}

model DailyHabit {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                DateTime  @default(now())
  usedBicycle         Boolean   @default(false)
  avoidedPlastic      Boolean   @default(false)
  usedPublicTransport Boolean   @default(false)
  savedElectricity    Boolean   @default(false)
  recycledWaste       Boolean   @default(false)
  carpooled           Boolean   @default(false)
  pointsEarned        Int       @default(0)

  @@index([userId, date])
}

model Challenge {
  id          String          @id @default(uuid())
  title       String          
  description String
  points      Int
  duration    Int             
  category    String          
  users       UserChallenge[]
}

model UserChallenge {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  status      String    @default("IN_PROGRESS") 
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([challengeId])
}

model ReceiptScan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String   
  scannedAt   DateTime @default(now())
  amount      Float
  co2Estimate Float
  rawText     String

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
}
